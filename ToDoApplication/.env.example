# このファイルをコピーして「.env」という名前で保存し、値を自分用に設定してください。
# 例: cp .env.example .env
#
# .env は .gitignore で除外されているため、GitHubには公開されません。

# SECRET_KEY: セッション暗号化用の秘密鍵。他人に推測されない値をランダムに設定すること。
# 生成例: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-this-to-your-own-random-value

# FLASK_DEBUG: デバッグモード。開発中は true、本番環境では必ず false にする。
FLASK_DEBUG=true
