[Unit]
Description=ToDo Application (Gunicorn)
After=network.target

[Service]
# 実際の環境に合わせて以下を変更すること
User=www-data
Group=www-data
WorkingDirectory=/path/to/ToDoApplication/ToDoApplication
EnvironmentFile=/path/to/ToDoApplication/ToDoApplication/.env
ExecStart=/path/to/ToDoApplication/ToDoApplication/venv/bin/gunicorn \
    -w 4 -b 127.0.0.1:8000 wsgi:app
Restart=always

[Install]
WantedBy=multi-user.target
